# {{ ansible_managed }}

---
# Supabase .env
# Generated by Ansible — do not edit manually

POSTGRES_PASSWORD={{ vault_supabase_postgres_password }}
JWT_SECRET={{ vault_supabase_jwt_secret }}
ANON_KEY={{ vault_supabase_anon_key }}
SERVICE_ROLE_KEY={{ vault_supabase_service_role_key }}
DASHBOARD_USERNAME={{ vault_supabase_dashboard_username | default('admin') }}
DASHBOARD_PASSWORD={{ vault_supabase_dashboard_password }}

SITE_URL=https://{{ supabase_domain | default('supabase.' + domain) }}
ADDITIONAL_REDIRECT_URLS={{ supabase_additional_redirect_urls | default('') }}

# Auth
ENABLE_EMAIL_SIGNUP={{ supabase_email_signup | default('true') }}
ENABLE_EMAIL_AUTOCONFIRM={{ supabase_email_autoconfirm | default('false') }}
ENABLE_ANONYMOUS_USERS={{ supabase_anonymous_users | default('false') }}

# SMTP
SMTP_ADMIN_EMAIL={{ smtp_admin_email | default('admin@' + domain) }}
SMTP_HOST={{ smtp_host | default('smtp') }}
SMTP_PORT={{ smtp_port | default('587') }}
SMTP_USER={{ vault_smtp_user | default('') }}
SMTP_PASS={{ vault_smtp_password }}
SMTP_SENDER_NAME={{ smtp_sender_name | default('Supabase') }}

# Storage
STORAGE_BACKEND=file
FILE_SIZE_LIMIT={{ supabase_file_size_limit | default('52428800') }}

# Studio
STUDIO_DEFAULT_ORGANIZATION={{ supabase_org_name | default('Home Datacenter') }}
STUDIO_DEFAULT_PROJECT={{ supabase_project_name | default('Default') }}
