version: "3.8"

services:
  traefik:
    image: traefik:v3.0
    container_name: supabase-traefik
    restart: unless-stopped
    command:
      - --entrypoints.supabase.address=:80
      - --providers.docker=true
      - --providers.docker.exposedbydefault=false
    ports:
      - "{{ supabase_traefik_port | default('127.0.0.1:8081:80') }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - traefik
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.supabase.rule=Host(`{{ supabase_domain | default('supabase.' + domain) }}`) && PathPrefix(`/`)"
      - "traefik.http.routers.supabase.entrypoints=web-secure"
      - "traefik.http.routers.supabase.tls=true"
      - "traefik.http.routers.supabase.tls.certresolver=default"
      - "traefik.http.services.supabase.loadbalancer.server.port=80"

  studio:
    image: supabase/studio:{{ supabase_version | default('latest') }}
    restart: unless-stopped
    environment:
      STUDIO_PG_META_URL: http://meta:8080
      POSTGRES_PASSWORD: {{ vault_supabase_postgres_password }}
      SUPABASE_URL: http://kong:8000
      SUPABASE_PUBLIC_URL: https://{{ supabase_domain | default('supabase.' + domain) }}
      SUPABASE_ANON_KEY: {{ vault_supabase_anon_key }}
      SUPABASE_SERVICE_ROLE_KEY: {{ vault_supabase_service_role_key }}
      AUTH_ENDPOINT: /auth/v1
      AUTH_EXTERNAL_ENABLED: "true"
      AUTH_EXTERRAL_GITHUB_ENABLED: "false"

  kong:
    image: kong:2.8.1
    restart: unless-stopped
    environment:
      KONG_DATABASE: "off"
      KONG_DECLARATIVE_CONFIG: /api/kong.yml
      KONG_DNS_ORDER: LAST,A
    volumes:
      - ./volumes/api/kong.yml:/api/kong.yml:ro

  auth:
    image: supabase/gotrue:{{ supabase_gotrue_version | default('v2.150.0') }}
    restart: unless-stopped
    environment:
      GOTRUE_API_HOST: 0.0.0.0
      API_EXTERNAL_URL: https://{{ supabase_domain | default('supabase.' + domain) }}
      GOTRUE_SITE_URL: https://{{ supabase_domain | default('supabase.' + domain) }}
      GOTRUE_JWT_SECRET: {{ vault_supabase_jwt_secret }}
      GOTRUE_DB_DRIVER: postgres
      GOTRUE_DB_DATABASE_URL: postgres://supabase_auth_admin:{{ vault_supabase_postgres_password }}@db:5432/supabase

  rest:
    image: postgrest/postgrest:{{ supabase_postgrest_version | default('v12.0.1') }}
    restart: unless-stopped
    environment:
      PGRST_DB_URI: postgres://authenticator:{{ vault_supabase_postgres_password }}@db:5432/postgres
      PGRST_DB_SCHEMA: public,storage,graphql_public
      PGRST_DB_ANON_ROLE: anon
      PGRST_JWT_SECRET: {{ vault_supabase_jwt_secret }}
      PGRST_DB_AGGREGATES_ENABLED: "true"

  realtime:
    image: supabase/realtime:{{ supabase_realtime_version | default('v2.28.7') }}
    restart: unless-stopped
    environment:
      PORT: 4000
      DB_HOST: db
      DB_PORT: 5432
      DB_USER: supabase_admin
      DB_PASSWORD: {{ vault_supabase_postgres_password }}
      DB_NAME: postgres
      DB_AFTER_CONNECT_QUERY: "SET search_path TO _realtime"
      JWT_SECRET: {{ vault_supabase_jwt_secret }}

  storage:
    image: supabase/storage-api:{{ supabase_storage_version | default('v1.0.6') }}
    restart: unless-stopped
    environment:
      ANON_KEY: {{ vault_supabase_anon_key }}
      SERVICE_KEY: {{ vault_supabase_service_role_key }}
      POSTGREST_URL: http://rest:3000
      PGRST_JWT_SECRET: {{ vault_supabase_jwt_secret }}
      FILE_SIZE_LIMIT: {{ supabase_file_size_limit | default('52428800') }}
      STORAGE_BACKEND: file
      FILE_STORAGE_PATH: /var/lib/storage
    volumes:
      - ./volumes/storage:/var/lib/storage

  meta:
    image: supabase/pg-meta:{{ supabase_pgmeta_version | default('v0.81.0') }}
    restart: unless-stopped
    environment:
      PG_META_PORT: 8080
      PG_META_DB_HOST: db
      PG_META_DB_PORT: 5432
      PG_META_DB_NAME: postgres
      PG_META_DB_USER: supabase_admin
      PG_META_DB_PASSWORD: {{ vault_supabase_postgres_password }}

  db:
    image: supabase/postgres:{{ supabase_pg_version | default('15.6.1.122') }}
    restart: unless-stopped
    healthcheck:
      test: pg_isready -U supabase_admin -d postgres
      interval: 10s
      timeout: 2s
      retries: 5
    environment:
      POSTGRES_PASSWORD: {{ vault_supabase_postgres_password }}
    volumes:
      - ./volumes/db:/var/lib/postgresql/data

  pgadmin:
    image: dpage/pgadmin4:latest
    restart: unless-stopped
    environment:
      PGADMIN_DEFAULT_EMAIL: {{ vault_pgadmin_email | default('admin@' + domain) }}
      PGADMIN_DEFAULT_PASSWORD: {{ vault_pgadmin_password }}
      PGADMIN_CONFIG_SERVER_MODE: "False"
    volumes:
      - ./volumes/pgadmin:/var/lib/pgadmin
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.pgadmin.rule=Host(`pgadmin.{{ domain }}`)"
      - "traefik.http.routers.pgadmin.entrypoints=web-secure"
      - "traefik.http.routers.pgadmin.tls=true"
      - "traefik.http.routers.pgadmin.tls.certresolver=default"
      - "traefik.http.services.pgadmin.loadbalancer.server.port=80"

volumes:
  db:
  storage:
  pgadmin:

networks:
  default:
    name: supabase
  traefik:
    external: true
