services:
  opencode-webhook:
    image: ghcr.io/opencode-ai/webhook:{{ opencode_webhook_version | default('latest') }}
    container_name: opencode-webhook
    restart: unless-stopped
    env_file:
      - .env
    networks:
      - traefik
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.opencode-webhook.rule=Host(`{{ opencode_webhook_domain | default('opencode-webhook.' + domain) }}`)"
      - "traefik.http.routers.opencode-webhook.entrypoints=web-secure"
      - "traefik.http.routers.opencode-webhook.tls=true"
      - "traefik.http.routers.opencode-webhook.tls.certresolver=default"
      - "traefik.http.services.opencode-webhook.loadbalancer.server.port=8000"

networks:
  traefik:
    external: true
