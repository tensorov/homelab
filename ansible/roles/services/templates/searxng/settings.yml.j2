---
# SearXNG settings.yml — generated by Ansible

use_default_settings: true

general:
  instance_name: "{{ searxng_instance_name | default('Search') }}"
  private_instance: {{ searxng_private | default('false') }}
  debug: false
  host: "0.0.0.0"

search:
  safe_search: {{ searxng_safe_search | default(0) }}
  autocomplete: "{{ searxng_autocomplete | default('') }}"
  default_lang: "{{ searxng_default_lang | default('auto') }}"
  formats:
    - html
    - json

server:
  secret_key: "{{ vault_searxng_secret_key }}"
  bind_address: "0.0.0.0"
  port: 8080
  limiter: {{ searxng_limiter_enabled | default('false') }}
  image_proxy: {{ searxng_image_proxy | default('false') }}
  method: "GET"

ui:
  static_use_hash: true
  default_theme: "{{ searxng_theme | default('simple') }}"
  default_locale: "{{ searxng_locale | default('en-US') }}"

enabled_plugins:
  - Basic Calculator
  - Hash plugin
  - Search on category select
  - Self Information
  - Tracker URL remover
  - Hostnames replace
  - Incoming mail
