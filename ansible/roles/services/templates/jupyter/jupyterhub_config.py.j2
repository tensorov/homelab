# {{ ansible_managed }}

# Configuration file for Jupyterhub
# Generated by Ansible — do not edit manually

import os

c = get_config()  # noqa

# ── Authentication (Authentik OIDC) ──────────────────────
c.JupyterHub.authenticator_class = "oauthenticator.generic.GenericOAuthenticator"
c.GenericOAuthenticator.client_id = os.environ["OAUTH_CLIENT_ID"]
c.GenericOAuthenticator.client_secret = os.environ["OAUTH_CLIENT_SECRET"]
c.GenericOAuthenticator.oauth_callback_url = os.environ["OAUTH_CALLBACK_URL"]
c.GenericOAuthenticator.authorize_url = os.environ["OAUTH_ISSUER"] + "/application/o/authorize/"
c.GenericOAuthenticator.token_url = os.environ["OAUTH_ISSUER"] + "/application/o/token/"
c.GenericOAuthenticator.userdata_url = os.environ["OAUTH_ISSUER"] + "/application/o/userinfo/"
c.GenericOAuthenticator.scope = ["openid", "email", "profile"]
c.GenericOAuthenticator.claim_groups_key = "groups"
c.GenericOAuthenticator.admin_users = {{ jupyter_admin_users | default('{"admin"}') }}

# ── Spawner (Docker) ─────────────────────────────────────
c.JupyterHub.spawner_class = "dockerspawner.DockerSpawner"
c.DockerSpawner.image = "{{ jupyter_notebook_image | default('jupyter/scipy-notebook:latest') }}"
c.DockerSpawner.network_name = "traefik"
c.DockerSpawner.extra_create_kwargs = {"user": "root"}
c.DockerSpawner.remove = True
c.DockerSpawner.debug = True
c.DockerSpawner.default_url = "/lab"
c.DockerSpawner.mem_limit = "{{ jupyter_mem_limit | default('1G') }}"
c.DockerSpawner.cpu_limit = {{ jupyter_cpu_limit | default(1) }}

# ── Proxy ────────────────────────────────────────────────
c.JupyterHub.hub_ip = "0.0.0.0"
c.JupyterHub.hub_bind_url = "http://0.0.0.0:8000"
c.ConfigurableHTTPProxy.command = ["configurable-http-proxy", "--redirect-port", "443"]
c.JupyterHub.proxy_class = "traefik"
c.JupyterHub.bind_url = "http://0.0.0.0:8000"

# ── Database ─────────────────────────────────────────────
c.JupyterHub.db_url = (
    f"postgresql+asyncpg://{os.environ['POSTGRES_USER']}:{os.environ['POSTGRES_PASSWORD']}"
    f"@{os.environ['POSTGRES_HOST']}/{os.environ['POSTGRES_DB']}"
)

# ── Crypt ────────────────────────────────────────────────
c.JupyterHub.cookie_secret_file = "/data/jupyterhub_cookie_secret"
c.ConfigurableHTTPProxy.auth_token = os.environ.get("JUPYTERHUB_CRYPT_KEY", "")
c.JupyterHub.crypt_key = os.environ.get("JUPYTERHUB_CRYPT_KEY", "")

# ── TLS (handled by Traefik) ─────────────────────────────
c.JupyterHub.ssl_enabled = False
c.JupyterHub.internal_certs = False

# ── Services ─────────────────────────────────────────────
c.JupyterHub.load_groups = {"{{ jupyter_users_group | default('jupyter-users') }}": {{ jupyter_allowed_users | default('[]') }}}
c.JupyterHub.active_user_window = {{ jupyter_active_window | default(3600) }}

# ── Custom ───────────────────────────────────────────────
c.JupyterHub.tornado_settings = {
    "headers": {
        "Content-Security-Policy": "frame-ancestors 'self' https://{{ domain }}",
    },
}
