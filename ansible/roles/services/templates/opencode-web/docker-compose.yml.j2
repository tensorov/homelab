services:
  opencode-web:
    image: ghcr.io/opencode-ai/web:latest
    container_name: opencode-web
    restart: unless-stopped
    env_file:
      - .env
    networks:
      - traefik
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.opencode-web.rule=Host(`{{ opencode_web_domain | default('opencode.' + domain) }}`)"
      - "traefik.http.routers.opencode-web.entrypoints=web-secure"
      - "traefik.http.routers.opencode-web.tls=true"
      - "traefik.http.routers.opencode-web.tls.certresolver=default"
      - "traefik.http.services.opencode-web.loadbalancer.server.port=3000"

networks:
  traefik:
    external: true
