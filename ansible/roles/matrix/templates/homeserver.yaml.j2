# Synapse homeserver.yaml — generated by Ansible
# Do not edit manually

server_name: "{{ matrix_homeserver_name | default('matrix.' + domain) }}"
pid_file: /data/homeserver.pid
listeners:
  - port: 8008
    bind_addresses: ["0.0.0.0"]
    type: http
    tls: false
    x_forwarded: true
    resources:
      - names: [client, federation]
        compress: true

database:
  name: psycopg2
  args:
    user: synapse
    password: {{ vault_matrix_postgres_password }}
    database: synapse
    host: db
    port: 5432
    cp_min: 5
    cp_max: 10

log_config: "/data/{{ matrix_homeserver_name | default('matrix.' + domain) }}.log.config"
media_store_path: "/data/media_store"
uploads_path: "/data/uploads"

enable_registration: {{ matrix_enable_registration | default('false') }}
enable_registration_without_verification: {{ matrix_enable_registration_without_verification | default('false') }}
registration_shared_secret: "{{ vault_matrix_registration_shared_secret }}"

report_stats: {{ matrix_report_stats | default('false') }}

macaroon_secret_key: "{{ vault_matrix_macaroon_secret }}"
form_secret: "{{ vault_matrix_form_secret }}"

# Signing keys (one per file)
signing_key_path: "/data/{{ matrix_homeserver_name | default('matrix.' + domain) }}.signing.key"
old_signing_keys: {}
trusted_key_servers:
  - server_name: "matrix.org"
    verify_keys:
      ed25519:auto

# Federation
federation_domain_whitelist: {{ matrix_federation_whitelist | default('[]') }}
federation_rc_window_size: 1000
federation_rc_sleep_limit: 10
federation_rc_sleep_delay: 500
federation_rc_reject_limit: 50
federation_rc_concurrent: 3

# Rate limiting
rc_login:
  address:
    per_second: 0.17
    burst_count: 3
  account:
    per_second: 0.17
    burst_count: 3
  failed_attempts_per_day: 5

# Turn server
turn_uris: []
turn_shared_secret: ""
turn_allow_guests: false

# SSO / OIDC
oidc_providers:
  - idp_id: authentik
    idp_name: "Authentik"
    discover: true
    issuer: "https://{{ authentik_domain | default('idp.' + domain) }}"
    client_id: "{{ vault_matrix_oidc_client_id }}"
    client_secret: "{{ vault_matrix_oidc_client_secret }}"
    scopes: ["openid", "profile", "email"]
    user_mapping_provider:
      config:
        localpart_template: "{{ user.preferred_username }}"
        display_name_template: "{{ user.name }}"
        email_template: "{{ user.email }}"

# Push
push:
  include_content: true

# Spam checker
spam_checker: null

# Cache
event_cache_size: "{{ matrix_event_cache_size | default('100K') }}"
caches:
  per_cache_factors:
    "get_users_in_room": 0.5
    "get_rooms_for_user": 0.5

# Limits
max_upload_size: "{{ matrix_max_upload_size | default('50M') }}"
max_avatar_size: "{{ matrix_max_avatar_size | default('1M') }}"
