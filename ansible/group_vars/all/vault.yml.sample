# ── THIS IS A SAMPLE — REPLACE WITH REAL ENCRYPTED VALUES ──
# Usage: ansible-vault encrypt group_vars/all/vault.yml
#
# All vault_* variables referenced by roles must be defined here.
#
# Template:
# ansible-vault encrypt_string --vault-id vault-password 'your-secret' --name 'vault_supabase_postgres_password'

# ── Required (must be set) ──────────────────────────────
#
# vault_supabase_postgres_password:
# vault_supabase_jwt_secret:
# vault_supabase_anon_key:
# vault_supabase_service_role_key:
# vault_supabase_dashboard_password:
# vault_supabase_dashboard_username:       # default: admin
#
# vault_authentik_secret_key:
# vault_authentik_postgres_password:
# vault_authentik_bootstrap_token:
# vault_authentik_bootstrap_password:
# vault_authentik_email_password:
# vault_authentik_client_id:
# vault_authentik_client_secret:
#
# vault_gitlab_root_password:
# vault_gitlab_secret_key:
# vault_gitlab_runner_token:
# vault_gitlab_postgres_password:
# vault_gitlab_smtp_password:
# vault_gitlab_email_from:
# vault_gitlab_email_reply_to:
# vault_gitlab_oauth_client_secret:
#
# vault_smtp_password:
# vault_smtp_user:
#
# vault_jupyter_postgres_password:
# vault_jupyterhub_crypt_key:
# vault_jupyter_oauth_client_id:
# vault_jupyter_oauth_client_secret:
#
# vault_searxng_secret_key:
#
# vault_mirotalk_oidc_client_id:
# vault_mirotalk_oidc_client_secret:
#
# vault_opencode_web_oauth_client_id:
# vault_opencode_web_oauth_client_secret:
#
# vault_pgadmin_email:
# vault_pgadmin_password:
#
# ── Cloudflare DNS ────────────────────────────────────
# Used by Traefik for DNS-01 ACME challenge (Let's Encrypt / ZeroSSL).
# Generate an API token at https://dash.cloudflare.com/profile/api-tokens
# with permissions: Zone → DNS → Edit (scoped to your domain zone).
# vault_cf_api_email:                                  # Cloudflare account email
# vault_cf_dns_api_token:                              # DNS API token (scoped)

# ── Monitoring / notifications ───────────────────────
# vault_telegram_bot_token:
# vault_telegram_chat_id:
#
# vault_restic_password:
#
# Backup remote (required for restic sync):
# restic_repository: s3:https://s3.eu-central-003.backblazeb2.com/your-bucket/homelab

# Example encrypted value (replace):
# vault_supabase_postgres_password: !vault |
#   $ANSIBLE_VAULT;1.1;AES256
#   66386439653236336[...]61383830356239
#   3139326131656164[...]64643261346632
#   6336376131363034[...]38613038343734
